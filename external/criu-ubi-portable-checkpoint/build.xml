<?xml version="1.0"?>
<project name="criu-ubi-portable-checkpoint" default="build" basedir=".">
	<taskdef resource="net/sf/antcontrib/antlib.xml" />
	<description>
		Build criu-ubi-portable-checkpoint Test
	</description>
	<import file="${TEST_ROOT}/external/build.xml"/>

	<!-- set properties for this build -->
	<property name="TEST" value="criu-ubi-portable-checkpoint" />
	<property name="DEST" value="${BUILD_ROOT}/external/${TEST}" />
	<property name="src" location="." />
	<if>
		<contains string="${TEST}" substring="ubi" />
		<then>
			<property name="docker_os" value="ubi"/>
		</then>
		<else>
			<property name="docker_os" value="ubuntu"/>
		</else>
	</if>

	<target name="init">
		<mkdir dir="${DEST}"/>
	</target>

	<target name="copy_resources" depends="move_scripts" description="copy criu resources">
		<copy todir="${DEST_EXTERNAL}/${TEST}/resources/criu/x86_64">
			<fileset dir="${src}/resources/criu/x86_64" includes="*"/>
		</copy>
	</target>

	<target name="dist" depends="copy_resources,clean_image,build_image" description="generate the distribution">
		<copy todir="${DEST}">
			<fileset dir="${src}" includes="*.xml, *.mk"/>
		</copy>
	</target>

	<target name="build">
		<antcall target="dist" inheritall="true" />
	</target>
</project>
